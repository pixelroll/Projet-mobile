<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    app:cardCornerRadius="16dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <!-- User Info -->
        <FrameLayout
            android:id="@+id/flUserAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="16dp"
            android:background="@drawable/circle_avatar_bg"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            
            <TextView
                android:id="@+id/tvAvatarInitials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="#0891b2"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="S" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#1A202C"
            app:layout_constraintStart_toEndOf="@id/flUserAvatar"
            app:layout_constraintTop_toTopOf="@id/flUserAvatar"
            app:layout_constraintBottom_toTopOf="@id/tvLocationHeader"
            tools:text="Sophie Martin" />

        <TextView
            android:id="@+id/tvLocationHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#718096"
            app:drawableStartCompat="@drawable/ic_location_on"
            app:drawableTint="#718096"
            android:drawablePadding="4dp"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="@id/tvUserName"
            app:layout_constraintTop_toBottomOf="@id/tvUserName"
            app:layout_constraintBottom_toBottomOf="@id/flUserAvatar"
            tools:text="Paris, France" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:textSize="13sp"
            android:textColor="#718096"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvUserName"
            app:layout_constraintBottom_toBottomOf="@id/tvUserName"
            tools:text="Janvier 2026" />

        <!-- Image -->
        <ImageView
            android:id="@+id/ivPhoto"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="4:5"
            android:scaleType="centerCrop"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/flUserAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Actions -->
        <ImageView
            android:id="@+id/ivLike"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:padding="4dp"
            android:src="@drawable/ic_favorite_border"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivPhoto" />

        <TextView
            android:id="@+id/tvLikesCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textSize="15sp"
            android:textColor="#1A202C"
            app:layout_constraintStart_toEndOf="@id/ivLike"
            app:layout_constraintTop_toTopOf="@id/ivLike"
            app:layout_constraintBottom_toBottomOf="@id/ivLike"
            tools:text="342" />

        <ImageView
            android:id="@+id/ivComment"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:padding="4dp"
            android:src="@drawable/ic_chat_bubble_outline"
            app:layout_constraintStart_toEndOf="@id/tvLikesCount"
            app:layout_constraintTop_toTopOf="@id/ivLike" />

        <TextView
            android:id="@+id/tvCommentsCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textSize="15sp"
            android:textColor="#1A202C"
            app:layout_constraintStart_toEndOf="@id/ivComment"
            app:layout_constraintTop_toTopOf="@id/ivComment"
            app:layout_constraintBottom_toBottomOf="@id/ivComment"
            tools:text="28" />

        <ImageView
            android:id="@+id/ivShare"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginStart="16dp"
            android:padding="4dp"
            android:src="@drawable/ic_share"
            app:layout_constraintStart_toEndOf="@id/tvCommentsCount"
            app:layout_constraintTop_toTopOf="@id/ivLike" />

        <ImageView
            android:id="@+id/ivBookmark"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_marginEnd="16dp"
            android:padding="4dp"
            android:src="@drawable/ic_bookmark_border"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivLike" />

        <!-- Location Chip -->
        <!-- We use a custom background for rounded chip -->
        <TextView
            android:id="@+id/tvLocationChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/chip_bg"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:textColor="#0891b2"
            android:textSize="13sp"
            android:textStyle="bold"
            app:drawableStartCompat="@drawable/ic_location_on"
            app:drawableTint="#0891b2"
            android:drawablePadding="6dp"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLike"
            tools:text="Tour Eiffel" />

        <!-- Name & Description Inline -->
        <TextView
            android:id="@+id/tvInlineDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:textSize="14sp"
            android:textColor="#1A202C"
            android:lineSpacingExtra="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLocationChip"
            tools:text="@tools:sample/lorem/random" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
