<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/detailRootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Back button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/on_background" />

        <!-- Delete button (only visible to author) -->
        <ImageButton
            android:id="@+id/btnDeletePhoto"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_trash"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/error" />

        <!-- Header: avatar | [name row / location+date row] — single unified block -->
        <LinearLayout
            android:id="@+id/authorSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_avatar_bg"
                android:backgroundTint="#E0F2F1">
                <TextView
                    android:id="@+id/tvAuthorInitialDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textColor="#00796B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="S" />
                <ImageView
                    android:id="@+id/ivAuthorAvatarDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <!-- Right column: name on top, location+date below -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Name (+ optional group badge) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tvAuthorNameDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_background"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Nom d'utilisateur" />
                    <TextView
                        android:id="@+id/tvGroupBadgeDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_icon_primary_10"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:textColor="#0891B2"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        app:drawableStartCompat="@drawable/ic_group"
                        app:drawableTint="#0891B2"
                        android:drawablePadding="4dp"
                        android:gravity="center_vertical"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:maxWidth="120dp"
                        tools:text="Voyage Paris 2026"
                        tools:visibility="visible" />
                </LinearLayout>

                <!-- Location + date row — tapping opens maps when location exists -->
                <LinearLayout
                    android:id="@+id/locationSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/ivLocationPin"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_map_pin"
                        android:visibility="gone"
                        app:tint="@color/muted_foreground" />

                    <TextView
                        android:id="@+id/tvLocationNameDetail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/muted_foreground"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:text="Champ de Mars, Paris" />

                    <ImageView
                        android:id="@+id/ivMapsLink"
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:layout_marginStart="3dp"
                        android:src="@drawable/ic_external_link"
                        android:visibility="gone"
                        app:tint="@color/primary" />

                    <TextView
                        android:id="@+id/tvLocationDateSeparator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="5dp"
                        android:text="|"
                        android:textColor="@color/muted_foreground"
                        android:textSize="12sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvDateDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/muted_foreground"
                        android:textSize="12sp"
                        tools:text="il y a 3 heures" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: Tags — single horizontal scrollable line -->
        <HorizontalScrollView
            android:id="@+id/tagsScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp"
            android:scrollbars="none"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/authorSection">

            <LinearLayout
                android:id="@+id/llTagsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <!-- Main photo — full height -->
        <ImageView
            android:id="@+id/ivPhotoDetail"
            android:layout_width="match_parent"
            android:layout_height="380dp"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toBottomOf="@id/tagsScrollView"
            tools:src="@drawable/circle_avatar_bg" />

        <!-- Parcours info — compact inline -->
        <LinearLayout
            android:id="@+id/parcoursSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/ivPhotoDetail">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_route"
                app:tint="@color/muted_foreground" />

            <TextView
                android:id="@+id/tvParcoursInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/muted_foreground"
                android:textSize="12sp"
                tools:text="Prise dans le parcours Visite de Paris, étape : Tour Eiffel" />
        </LinearLayout>

        <!-- Action bar: [♥] count — spacer — [voir parcours] [⚑] -->
        <LinearLayout
            android:id="@+id/actionBarDetail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/parcoursSection">

            <ImageView
                android:id="@+id/ivLikeDetail"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_favorite_border"
                app:tint="@color/on_background" />

            <TextView
                android:id="@+id/tvLikesCountDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textColor="@color/on_background"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="342" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoirParcours"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:paddingHorizontal="14dp"
                android:text="Voir le parcours"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:visibility="gone"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="8dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp" />

            <ImageButton
                android:id="@+id/ivReportDetail"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_flag"
                app:tint="@color/muted_foreground" />
        </LinearLayout>

        <!-- CTA "Envie de visiter ce lieu?" — only when liked -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCTAVisit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/transparent"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/actionBarDetail">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_cta_gradient"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_primary_10">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_route"
                        app:tint="@color/primary" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Envie de visiter ce lieu ?"
                        android:textColor="@color/on_background"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvCTASubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/muted_foreground"
                        android:textSize="12sp"
                        tools:text="Générez un parcours de visite autour de Champ de Mars" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCreatePathDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginTop="8dp"
                        android:insetBottom="0dp"
                        android:insetTop="0dp"
                        android:paddingHorizontal="12dp"
                        android:text="Créer un parcours"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="6dp"
                        app:icon="@drawable/ic_route"
                        app:iconSize="14dp"
                        app:iconTint="@color/white" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Audio note -->
        <LinearLayout
            android:id="@+id/audioNoteSection"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_white_border_gray"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/cardCTAVisit">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_mic_lucide"
                app:tint="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Écouter la note audio"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#EEEEEE"
            app:layout_constraintTop_toBottomOf="@id/audioNoteSection" />

        <!-- Comments Section -->
        <LinearLayout
            android:id="@+id/commentsSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/divider1">

            <TextView
                android:id="@+id/tvCommentsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Commentaires"
                android:textColor="@color/on_background"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvComments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                tools:itemCount="3"
                tools:listitem="@layout/item_comment" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etComment"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_gray_rounded"
                    android:hint="Ajouter un commentaire..."
                    android:paddingHorizontal="16dp"
                    android:textSize="14sp" />

                <FrameLayout
                    android:id="@+id/btnSendComment"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_icon_teal_rounded"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_send"
                        app:tint="@color/primary" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Travel Info Section -->
        <LinearLayout
            android:id="@+id/travelInfoSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/commentsSection">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="16dp"
                android:background="#EEEEEE" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informations de voyage"
                android:textColor="@color/on_background"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTravelInfoDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/muted_foreground"
                android:textSize="14sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
