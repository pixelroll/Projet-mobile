<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="12dp">

    <!-- Timeline vertical line -->
    <View
        android:id="@+id/timelineLine"
        android:layout_width="1.5dp"
        android:layout_height="0dp"
        android:background="#0891b2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/timeBubble"
        app:layout_constraintEnd_toEndOf="@id/timeBubble"
        app:layout_constraintTop_toBottomOf="@id/timeBubble" />

    <!-- Time Bubble -->
    <FrameLayout
        android:id="@+id/timeBubble"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_circle_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvTimeBubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="09:00" />
    </FrameLayout>

    <!-- Card Content -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/timeBubble"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- Image -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivStepImage"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
                    tools:src="@drawable/profile_sophie" />

                <!-- Content Column -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <!-- Title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:id="@+id/ivTypeIcon"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            app:tint="#0891b2"
                            tools:src="@drawable/ic_coffee" />
                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:textColor="#212121"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="Petit-déjeuner au Café de Flore" />
                    </LinearLayout>

                    <!-- Description -->
                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="#9E9E9E"
                        android:textSize="12sp"
                        tools:text="Café historique du quartier Saint-Germain" />

                    <!-- Hours -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_clock"
                            app:tint="#9E9E9E" />
                        <TextView
                            android:id="@+id/tvHours"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textColor="#616161"
                            android:textSize="12sp"
                            tools:text="07:30 – 01:30" />
                    </LinearLayout>

                    <!-- Status Badge -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_badge_facile"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:minHeight="22dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:textColor="#388E3C"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        tools:text="Ouvert" />

                    <!-- Duration & Price -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@drawable/ic_clock"
                            app:tint="#9E9E9E" />
                        <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"
                            tools:text="1h" />

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"
                            tools:text="15€" />
                    </LinearLayout>

                    <!-- Period Badge -->
                    <TextView
                        android:id="@+id/tvPeriod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:minHeight="22dp"
                        android:gravity="center"
                        android:singleLine="true"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        tools:background="@drawable/bg_badge_primary"
                        tools:text="Après-midi" />

                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Media Info Toggle (Full Width) -->
            <LinearLayout
                android:id="@+id/llMediaInfoToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_image"
                    app:tint="#0891b2" />

                <TextView
                    android:id="@+id/tvMediaInfo"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:textColor="#0891b2"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="2 photos • 1 vidéo" />

                <ImageView
                    android:id="@+id/ivChevron"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_down"
                    app:tint="#0891b2" />
            </LinearLayout>

            <!-- Expanded Photos Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStepPhotos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:listitem="@layout/item_step_photo" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
