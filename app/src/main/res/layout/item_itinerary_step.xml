<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Step row: bubble + card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left: step number bubble -->
        <FrameLayout
            android:id="@+id/timeBubble"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_circle_primary">
            <TextView
                android:id="@+id/tvTimeBubble"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="1" />
        </FrameLayout>

        <!-- Right: card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="10dp"
            app:cardElevation="2dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/ivTypeIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        app:tint="#0891b2"
                        tools:src="@drawable/ic_compass" />

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="#212121"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="Tour Eiffel" />

                    <!-- Delete button (edit mode only) -->
                    <ImageView
                        android:id="@+id/btnDeleteStep"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_trash"
                        android:layout_marginEnd="4dp"
                        android:visibility="gone"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#EF4444" />

                    <!-- Period badge -->
                    <TextView
                        android:id="@+id/tvPeriod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        tools:background="@drawable/bg_badge_primary"
                        tools:text="Matin" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0" />

                <!-- Description + meta -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#616161"
                        android:textSize="13sp"
                        tools:text="Monument emblématique de Paris, vue panoramique sur la ville." />

                    <!-- Duration + Price row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:src="@drawable/ic_clock"
                            app:tint="#9E9E9E" />
                        <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"
                            tools:text="90 min" />

                        <ImageView
                            android:layout_width="13dp"
                            android:layout_height="13dp"
                            android:layout_marginStart="16dp"
                            android:src="@drawable/ic_euro"
                            app:tint="#9E9E9E" />
                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp"
                            tools:text="26€" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Media toggle (photos section) -->
                <LinearLayout
                    android:id="@+id/llMediaInfoToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_image"
                        app:tint="#0891b2" />

                    <TextView
                        android:id="@+id/tvMediaInfo"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:textColor="#0891b2"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="2 photos" />

                    <ImageView
                        android:id="@+id/ivChevron"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chevron_down"
                        app:tint="#0891b2" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStepPhotos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    tools:listitem="@layout/item_step_photo" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Travel connector: shown between steps, hidden for last step -->
    <LinearLayout
        android:id="@+id/llTravelConnector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Vertical line segment -->
        <View
            android:id="@+id/timelineLine"
            android:layout_width="1.5dp"
            android:layout_height="28dp"
            android:layout_marginEnd="18dp"
            android:background="#0891b2" />

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_navigation"
            app:tint="#9E9E9E" />

        <TextView
            android:id="@+id/tvTravelInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="#9E9E9E"
            android:textSize="12sp"
            tools:text="15 min · marche" />
    </LinearLayout>


</LinearLayout>
