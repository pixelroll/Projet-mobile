<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#424242"/> <!-- Dark gray track -->
            <corners android:radius="2dp"/>
        </shape>
    </item>
    <item android:left="16dp" android:right="120dp" android:top="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#9E9E9E"/> <!-- Lighter thumb -->
            <corners android:radius="2dp"/>
        </shape>
    </item>
</layer-list>
