<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- 5% opacity of primary (#0891b2) to accent/secondary (#14b8a6) -->
    <gradient
        android:startColor="#0D0891b2"
        android:endColor="#0D14b8a6"
        android:angle="0" />
    
    <!-- 20% opacity of primary for the border -->
    <stroke
        android:width="1dp"
        android:color="#330891b2" />
        
    <corners android:radius="12dp" />
</shape>
